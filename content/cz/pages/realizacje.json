  "body": "<section class=\"container hub-hero\">\n    <p class=\"eyebrow\">Naše projekty</p>\n    <h1 class=\"h1\">Pavilony, které už stojí <span class=\"accent\">a vydělávají.</span></h1>\n    <p class=\"hub-sub\">Každý pavilon jiný — každý pro konkrétního zákazníka. Obchody, kanceláře, kavárny, domky, zázemí staveb. Rozmístěné po celém Polsku i v zahraničí.</p>\n  </section>\n\n  <section class=\"hub-grid-section\">\n    <div class=\"container\">\n      <p class=\"eyebrow\" style=\"text-align:left;margin-bottom:8px\">Zvenku</p>\n      <h2 class=\"h2\" style=\"text-align:left;margin-bottom:16px\">Pavilony a kontejnery</h2>\n      <p class=\"section-sub\" style=\"text-align:left;margin-left:0;max-width:680px\">Takto vypadají naše pavilony, když už stojí u zákazníků. Klikněte na fotografii pro zvětšení a prohlédnutí zblízka.</p>\n      <div class=\"realizacje-grid\" style=\"margin-top:32px\">\n        <div class=\"realizacja-card\"><img src=\"assets/gallery/realizacje/rz1.webp\" alt=\"Modulární pavilon STAGO\" loading=\"lazy\"></div>\n        <div class=\"realizacja-card\"><img src=\"assets/gallery/realizacje/rz2.webp\" alt=\"Modulární pavilon STAGO\" loading=\"lazy\"></div>\n        <div class=\"realizacja-card\"><img src=\"assets/gallery/realizacje/rz3.webp\" alt=\"Modulární pavilon STAGO\" loading=\"lazy\"></div>\n        <div class=\"realizacja-card\"><img src=\"assets/gallery/realizacje/rz4.webp\" alt=\"Modulární pavilon STAGO\" loading=\"lazy\"></div>\n        <div class=\"realizacja-card\"><img src=\"assets/gallery/realizacje/rz5.webp\" alt=\"Modulární pavilon STAGO\" loading=\"lazy\"></div>\n        <div class=\"realizacja-card\"><img src=\"assets/gallery/realizacje/rz6.webp\" alt=\"Modulární pavilon STAGO\" loading=\"lazy\"></div>\n        <div class=\"realizacja-card\"><img src=\"assets/gallery/realizacje/rz7.webp\" alt=\"Modulární pavilon STAGO\" loading=\"lazy\"></div>\n        <div class=\"realizacja-card\"><img src=\"assets/gallery/realizacje/rz8.webp\" alt=\"Modulární pavilon STAGO\" loading=\"lazy\"></div>\n        <div class=\"realizacja-card\"><img src=\"assets/gallery/realizacje/rz9.webp\" alt=\"Modulární pavilon STAGO\" loading=\"lazy\"></div>\n        <div class=\"realizacja-card\"><img src=\"assets/gallery/realizacje/rz10.webp\" alt=\"Modulární pavilon STAGO\" loading=\"lazy\"></div>\n        <div class=\"realizacja-card\"><img src=\"assets/gallery/realizacje/rz11.webp\" alt=\"Modulární pavilon STAGO\" loading=\"lazy\"></div>\n        <div class=\"realizacja-card\"><img src=\"assets/gallery/realizacje/rz12.webp\" alt=\"Modulární pavilon STAGO\" loading=\"lazy\"></div>\n        <div class=\"realizacja-card\"><img src=\"assets/gallery/realizacje/rz13.webp\" alt=\"Modulární pavilon STAGO\" loading=\"lazy\"></div>\n        <div class=\"realizacja-card\"><img src=\"assets/gallery/realizacje/rz14.webp\" alt=\"Modulární pavilon STAGO\" loading=\"lazy\"></div>\n        <div class=\"realizacja-card\"><img src=\"assets/gallery/realizacje/r2.webp\" alt=\"Modulární pavilon STAGO\" loading=\"lazy\"></div>\n        <div class=\"realizacja-card\"><img src=\"assets/gallery/realizacje/r5.webp\" alt=\"Modulární pavilon STAGO\" loading=\"lazy\"></div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"section section-light\">\n    <div class=\"container\">\n      <p class=\"eyebrow\" style=\"text-align:left;margin-bottom:8px\">Zevnitř</p>\n      <h2 class=\"h2\" style=\"text-align:left;margin-bottom:16px\">Interiéry pavilonů</h2>\n      <p class=\"section-sub\" style=\"text-align:left;margin-left:0;max-width:680px\">Světlé, připravené k dokončení nebo rovnou k nastěhování — podle toho, co si zákazník objedná. Takto vypadá vnitřek, než přijde dokončovací tým nebo první zaměstnanec.</p>\n      <div class=\"realizacje-grid\" style=\"margin-top:32px\">\n        <div class=\"realizacja-card\"><img src=\"assets/gallery/realizacje/rw1.webp\" alt=\"Modulární pavilon STAGO\" loading=\"lazy\"></div>\n        <div class=\"realizacja-card\"><img src=\"assets/gallery/realizacje/rw2.webp\" alt=\"Modulární pavilon STAGO\" loading=\"lazy\"></div>\n        <div class=\"realizacja-card\"><img src=\"assets/gallery/realizacje/rw3.webp\" alt=\"Modulární pavilon STAGO\" loading=\"lazy\"></div>\n        <div class=\"realizacja-card\"><img src=\"assets/gallery/realizacje/rw4.webp\" alt=\"Modulární pavilon STAGO\" loading=\"lazy\"></div>\n        <div class=\"realizacja-card\"><img src=\"assets/gallery/realizacje/rw5.webp\" alt=\"Modulární pavilon STAGO\" loading=\"lazy\"></div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"section section-dark\">\n    <div class=\"container\" style=\"text-align:center\">\n      <p class=\"eyebrow\">Teď jste na řadě vy</p>\n      <h2 class=\"h2\">Další realizace může být vaše.</h2>\n      <p style=\"color:var(--t-light2);font-size:1.05rem;max-width:600px;margin:16px auto 32px\">Vyberte model nebo nám řekněte, co potřebujete. Zbytek nechte na nás.</p>\n      <div style=\"display:flex;gap:16px;justify-content:center;flex-wrap:wrap\">\n        <a href=\"modele.html\" class=\"btn btn-primary btn-lg\">Zobrazit všech 12 modelů</a>\n        <a href=\"konfigurator.html\" class=\"btn btn-outline-light\">Bezplatná kalkulace</a>\n      </div>\n    </div>\n  </section>\n\n  <style>\n  .realizacja-card img{cursor:zoom-in}\n  .stago-lb{position:fixed;inset:0;background:rgba(15,14,13,.95);display:none;align-items:center;justify-content:center;z-index:100000;padding:24px}\n  .stago-lb.open{display:flex}\n  .stago-lb img{max-width:94vw;max-height:90vh;border-radius:8px;box-shadow:0 24px 70px rgba(0,0,0,.55)}\n  .stago-lb button{position:absolute;background:rgba(255,255,255,.12);border:0;color:#fff;cursor:pointer;border-radius:50%}\n  .stago-lb .lb-close{top:18px;right:22px;width:48px;height:48px;font-size:30px;line-height:1}\n  .stago-lb .lb-nav{top:50%;transform:translateY(-50%);width:56px;height:56px;font-size:30px}\n  .stago-lb .lb-prev{left:20px}.stago-lb .lb-next{right:20px}\n  .stago-lb button:hover{background:rgba(255,255,255,.22)}\n  @media(max-width:768px){.stago-lb .lb-nav{width:44px;height:44px;font-size:24px}}\n  </style>\n  <div class=\"stago-lb\" id=\"stago-lb\">\n    <button class=\"lb-close\" id=\"lb-close\" aria-label=\"X\">&times;</button>\n    <button class=\"lb-nav lb-prev\" id=\"lb-prev\" aria-label=\"&lt;\">&#8249;</button>\n    <img id=\"lb-img\" src=\"\" alt=\"\">\n    <button class=\"lb-nav lb-next\" id=\"lb-next\" aria-label=\"&gt;\">&#8250;</button>\n  </div>\n  <script>\n  (function(){\n    var lb=document.getElementById('stago-lb'),big=document.getElementById('lb-img'),i=0,imgs=[];\n    if(!lb||!big)return;\n    function collect(){imgs=[].slice.call(document.querySelectorAll('.realizacje-grid img'));}\n    function show(n){if(!imgs.length)return;i=(n+imgs.length)%imgs.length;big.src=imgs[i].src;big.alt=imgs[i].alt||'';}\n    function open(n){show(n);lb.classList.add('open');document.body.style.overflow='hidden';}\n    function close(){lb.classList.remove('open');document.body.style.overflow='';}\n    collect();\n    document.addEventListener('click',function(e){\n      var im=e.target&&e.target.closest?e.target.closest('.realizacje-grid img'):null;\n      if(im){collect();open(imgs.indexOf(im));return;}\n      var id=e.target&&e.target.id;\n      if(e.target===lb||id==='lb-close'){close();}\n      else if(id==='lb-prev'){show(i-1);}\n      else if(id==='lb-next'){show(i+1);}\n    });\n    document.addEventListener('keydown',function(e){if(!lb.classList.contains('open'))return;if(e.key==='Escape')close();else if(e.key==='ArrowLeft')show(i-1);else if(e.key==='ArrowRight')show(i+1);});\n  })();\n  </script>",
